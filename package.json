{
  "name": "bluprint",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "devDependencies": {
    "@types/bun": "latest",
    "prettier": "^3.7.4"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@clack/prompts": "^0.11.0",
    "@opencode-ai/sdk": "^1.0.169",
    "@types/yargs": "^17.0.35",
    "neverthrow": "^8.2.0",
    "yargs": "^18.0.0",
    "zod": "^4.3.5"
  },
  "scripts": {
    "typecheck": "bun tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\""
  }
}
